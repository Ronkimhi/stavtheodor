   "title": "Cathedral Window",
   "year": 2007,
   "image": {
    "file": "File:Kölner Dom - Richterfenster an der Südseite bei Nacht (7264-66).jpg",
    "thumb640": "https://upload.wikimedia.org/wikipedia/commons/thumb/9/99/K%C3%B6lner_Dom_-_Richterfenster_an_der_S%C3%BCdseite_bei_Nacht_%287264-66%29.jpg/960px-K%C3%B6lner_Dom_-_Richterfenster_an_der_S%C3%BCdseite_bei_Nacht_%287264-66%29.jpg",
    "thumb1600": "https://upload.wikimedia.org/wikipedia/commons/thumb/9/99/K%C3%B6lner_Dom_-_Richterfenster_an_der_S%C3%BCdseite_bei_Nacht_%287264-66%29.jpg/1920px-K%C3%B6lner_Dom_-_Richterfenster_an_der_S%C3%BCdseite_bei_Nacht_%287264-66%29.jpg",
    "pxW": 2200,
