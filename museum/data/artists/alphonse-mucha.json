   "title": "Gismonda",
   "year": 1894,
   "image": {
    "file": "File:Alfons Mucha - 1894 - Gismonda.jpg",
    "thumb640": "https://upload.wikimedia.org/wikipedia/commons/2/2f/Alfons_Mucha_-_1894_-_Gismonda.jpg",
    "thumb1600": "https://upload.wikimedia.org/wikipedia/commons/2/2f/Alfons_Mucha_-_1894_-_Gismonda.jpg",
